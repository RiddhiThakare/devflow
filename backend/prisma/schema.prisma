generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  email        String    @unique
  passwordHash String
  role         Role      @default(DEVELOPER)
  createdAt    DateTime  @default(now())
  projects     Project[]

  @@map("users")
}

enum Role {
  ADMIN
  DEVELOPER
  VIEWER
}

model Project {
  id          String     @id @default(uuid())
  name        String
  description String?
  ownerId     String
  owner       User       @relation(fields: [ownerId], references: [id])
  pipelines   Pipeline[]
  createdAt   DateTime   @default(now())

  @@map("projects")
}

model Pipeline {
  id         String        @id @default(uuid())
  name       String
  yamlConfig String
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id])
  runs       PipelineRun[]
  createdAt  DateTime      @default(now())

  @@map("pipelines")
}

model PipelineRun {
  id          String      @id @default(uuid())
  pipelineId  String
  pipeline    Pipeline    @relation(fields: [pipelineId], references: [id])
  status      RunStatus   @default(PENDING)
  logs        String      @default("")
  triggeredAt DateTime    @default(now())
  finishedAt  DateTime?

  @@map("pipeline_runs")
}

enum RunStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}